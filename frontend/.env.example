# ── Supabase ───────────────────────────────────────────────────────────────────
# Must match the values in the root .env
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJ...

# ── n8n ────────────────────────────────────────────────────────────────────────
# The same webhook URL used by the agent — the frontend fires this when
# a new research job is queued
REACT_APP_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/competitive-research

# ── Agent server ───────────────────────────────────────────────────────────────
# Local development URL for the Express agent server
# In production, point this at your deployed agent host
REACT_APP_AGENT_URL=http://localhost:3001
